# ===== 必填：GitLab 实例地址与 Personal Access Token =====
# Token 在 GitLab → User Settings → Access Tokens 创建，scope 必须勾选 read_api
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# ===== 可选：SSL 与网络 =====
# true / false / CA 证书文件路径（如 C:\certs\ca-bundle.crt）
GITLAB_SSL_VERIFY=true
GITLAB_TIMEOUT=30

# ===== 可选：Web 服务监听地址 =====
WEB_HOST=127.0.0.1
WEB_PORT=8000

# ===== 可选：GitLab 分页大小（最大 100）=====
PAGE_SIZE=100

# ===== 可选：SQLite 持久化文件路径 =====
# 用于看板拖拽覆盖、列配置、最近用户、主题偏好
DB_PATH=data/app.db