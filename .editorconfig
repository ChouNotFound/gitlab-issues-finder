# EditorConfig helps maintain consistent coding styles across editors.
# https://editorconfig.org/
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_size = 4
max_line_length = 100

[*.{html,css,js,md,json,yaml,yml,toml,xml,svg}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # 末尾两个空格表示换行

[*.ps1]
indent_size = 4
end_of_line = crlf  # Windows 习惯

[*.bat]
indent_size = 4
end_of_line = crlf

[Makefile]
indent_style = tab
